{% extends "base.html" %}

{% block title %}Clientes{% endblock %}

{% block content %}
<div class="container-fluid mt-4">
	<div class="row">
		<div class="col-12">
			<!-- Cabeçalho -->
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h2><i class="fas fa-users text-primary"></i> Gestão de Clientes</h2>
				<a href="{{ url_for('clientes.add_cliente') }}" class="btn btn-success">
					<i class="fas fa-plus"></i> Novo Cliente
				</a>
			</div>

			<!-- Filtros -->
			<div class="card mb-4">
				<div class="card-body">
					<form method="GET" class="row g-3">
						<div class="col-md-5">
							<label for="nome" class="form-label">Nome</label>
							<input type="text" class="form-control" id="nome" name="nome"
								value="{{ request.args.get('nome', '') }}" placeholder="Buscar por nome...">
						</div>
						<div class="col-md-5">
							<label for="email" class="form-label">Email</label>
							<input type="email" class="form-control" id="email" name="email"
								value="{{ request.args.get('email', '') }}" placeholder="Buscar por email...">
						</div>
						<div class="col-md-2 d-flex align-items-end">
							<button type="submit" class="btn btn-primary me-2">
								<i class="fas fa-search"></i> Buscar
							</button>
							<a href="{{ url_for('clientes.list_clientes') }}" class="btn btn-outline-secondary">
								<i class="fas fa-times"></i>
							</a>
						</div>
					</form>
				</div>
			</div>

			<!-- Tabela de Clientes -->
			<div class="card">
				<div class="card-header">
					<h5 class="mb-0">
						<i class="fas fa-list"></i> Lista de Clientes
						<span class="badge bg-primary ms-2">{{ clientes|length }}</span>
					</h5>
				</div>
				<div class="card-body">
					{% if clientes %}
					<div class="table-responsive">
						<table class="table table-hover">
							<thead class="table-dark">
								<tr>
									<th>ID</th>
									<th>Nome</th>
									<th>Email</th>
									<th>Telefone</th>
									<th>CPF</th>
									<th>Status</th>
									<th class="text-center">Ações</th>
								</tr>
							</thead>
							<tbody>
								{% for cliente in clientes %}
								<tr>
									<td><strong>#{{ cliente.id }}</strong></td>
									<td>{{ cliente.nome }}</td>
									<td>{{ cliente.email }}</td>
									<td>{{ cliente.telefone or '-' }}</td>
									<td>{{ cliente.cpf or '-' }}</td>
									<td>
										{% if cliente.status == 'ativo' %}
										<span class="badge bg-success">Ativo</span>
										{% else %}
										<span class="badge bg-secondary">{{ cliente.status|title }}</span>
										{% endif %}
									</td>
									<td class="text-center">
										<div class="btn-group" role="group">
											<a href="{{ url_for('clientes.view_cliente', id=cliente.id) }}"
												class="btn btn-sm btn-outline-info" title="Visualizar">
												<i class="fas fa-eye"></i>
											</a>
											<a href="{{ url_for('clientes.edit_cliente', id=cliente.id) }}"
												class="btn btn-sm btn-outline-warning" title="Editar">
												<i class="fas fa-edit"></i>
											</a>
											<button type="button" class="btn btn-sm btn-outline-danger"
												onclick="confirmarExclusao({{ cliente.id }}, '{{ cliente.nome }}')"
												title="Excluir">
												<i class="fas fa-trash"></i>
											</button>
										</div>
									</td>
								</tr>
								{% endfor %}
							</tbody>
						</table>
					</div>
					{% else %}
					<div class="text-center py-5">
						<i class="fas fa-users fa-3x text-muted mb-3"></i>
						<h4 class="text-muted">Nenhum cliente encontrado</h4>
						<p class="text-muted">Comece adicionando seu primeiro cliente!</p>
						<a href="{{ url_for('clientes.add_cliente') }}" class="btn btn-success">
							<i class="fas fa-plus"></i> Adicionar Cliente
						</a>
					</div>
					{% endif %}
				</div>
			</div>
		</div>
	</div>
</div>

<!-- Modal de Confirmação de Exclusão -->
<div class="modal fade" id="modalExclusao" tabindex="-1">
	<div class="modal-dialog">
		<div class="modal-content">
			<div class="modal-header">
				<h5 class="modal-title">Confirmar Exclusão</h5>
				<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
			</div>
			<div class="modal-body">
				<p>Tem certeza que deseja excluir o cliente <strong id="nomeCliente"></strong>?</p>
				<p class="text-danger"><small>Esta ação não pode ser desfeita.</small></p>
			</div>
			<div class="modal-footer">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
				<a href="#" id="btnConfirmarExclusao" class="btn btn-danger">Excluir</a>
			</div>
		</div>
	</div>
</div>

<script>
	function confirmarExclusao(id, nome) {
		document.getElementById('nomeCliente').textContent = nome;
		document.getElementById('btnConfirmarExclusao').href = "{{ url_for('clientes.delete_cliente', id=0) }}".replace('0', id);
		new bootstrap.Modal(document.getElementById('modalExclusao')).show();
	}
</script>
{% endblock %}